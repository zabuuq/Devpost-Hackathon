theme_override_colors/font_color = Color(0.4, 0.8, 1.0, 1.0)

[node name="HowToText" type="Label" parent="HowToPlayOverlay/Panel"]
text = "OBJECTIVE
Destroy your opponent's entire fleet before they destroy yours.

HOW TO PLAY
1. Each player secretly places their fleet on their grid.
2. Players take turns — use probes, lasers, and missiles to find and destroy the enemy fleet.
3. PROBE: Reveals enemy ship positions in a 4x4 area (6x6 for Probe Ship).
4. LASER: Fires at a target cell. Hits shields first, then armor.
5. MISSILE: High armor damage, bypasses shields partially.
6. MOVE: Reposition your ship. Forward costs half a move point.
7. Energy regenerates each turn — manage it carefully.
8. Probe intel fades after a few turns. Ghost markers remain.
9. The player who destroys all enemy ships wins.

ENERGY SLIDERS
Shield Regen fires at end of turn. Laser Power sets your shot strength.
Shields take priority if energy is low."
autowrap_mode = 2
theme_override_font_sizes/font_size = 14

[node name="CloseButton" type="Button" parent="HowToPlayOverlay/Panel"]
